        document.getElementById('emailPreviewContainer').innerHTML = htmlEmail;
        window.currentEmailHtml = htmlEmail;
    }
    
    // copy email
    function copyEmailToClipboard() {
        if(!window.currentEmailHtml) { alert("No email generated. Please select a hotel."); return; }
        navigator.clipboard.writeText(window.currentEmailHtml).then(() => {
            const btn = document.getElementById('copyEmailBtn');
            const original = btn.innerText;
            btn.innerText = "✅ Copied!";
            setTimeout(() => btn.innerText = original, 2000);
        }).catch(() => alert("Manual copy: select all email content"));
    }
    
    function refreshHotelInsights() {
        const hotel = document.getElementById('hotelSelect').value;
        const area = document.getElementById('areaSelect').value;
        currentArea = area;
        if(!rawExcelData || !hotel) return;
        updateUIForHotel(hotel, rawExcelData, area);
    }
    
    // file handling
    function loadFileAndPopulate(file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const data = new Uint8Array(e.target.result);
                const parsed = parseLighthouseExcel(data.buffer);
                rawExcelData = parsed;
                allHotelNames = parsed.allProperties;
                const select = document.getElementById('hotelSelect');
                select.innerHTML = '<option value="">— Select hotel —</option>' + allHotelNames.map(h => `<option value="${escapeHtml(h)}">${escapeHtml(h)}</option>`).join('');
                document.getElementById('fileInfo').style.display = 'block';
                document.getElementById('fileName').innerText = file.name;
                if(allHotelNames.length) {
                    select.value = allHotelNames[0];
                    refreshHotelInsights();
                }
            } catch(err) {
                alert("Error parsing file: " + err.message);
            }
        };
        reader.readAsArrayBuffer(file);
    }
    
    function escapeHtml(str) { if(!str) return ''; return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'})[m]); }
    
    // events
    document.getElementById('chooseFileBtn').addEventListener('click', () => document.getElementById('fileInput').click());
    document.getElementById('fileInput').addEventListener('change', (e) => { if(e.target.files[0]) loadFileAndPopulate(e.target.files[0]); });
    const dropzone = document.getElementById('dropzone');
    dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('drag-active'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-active'));
    dropzone.addEventListener('drop', (e) => { e.preventDefault(); dropzone.classList.remove('drag-active'); const file = e.dataTransfer.files[0]; if(file) loadFileAndPopulate(file); });
    document.getElementById('refreshInsightsBtn').addEventListener('click', refreshHotelInsights);
    document.getElementById('copyEmailBtn').addEventListener('click', copyEmailToClipboard);
    document.getElementById('markSentBtn').addEventListener('click', () => { const hotel = document.getElementById('hotelSelect').value; if(!hotel) return; markSent(hotel); });
    document.getElementById('markFollowup1Btn').addEventListener('click', () => { const hotel = document.getElementById('hotelSelect').value; if(!hotel) return; markFollowup(hotel,1); });
    document.getElementById('markFollowup2Btn').addEventListener('click', () => { const hotel = document.getElementById('hotelSelect').value; if(!hotel) return; markFollowup(hotel,2); });
    document.getElementById('exportTrackerBtn').addEventListener('click', () => {
        let csv = "Hotel,Area,Sent Date,Followup1 Sent,Followup2 Sent,Reply Received\n";
        for(let [h, e] of Object.entries(campaignTracker)) {
            csv += `"${h}","${e.area || ''}","${e.sentDate || ''}",${e.followup1Sent},${e.followup2Sent},${e.replyReceived}\n`;
        }
        const blob = new Blob([csv], {type: 'text/csv'});
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'campaign_tracker.csv'; a.click(); URL.revokeObjectURL(a.href);
    });
    document.getElementById('resetTrackerBtn').addEventListener('click', () => { if(confirm('Delete all tracking data?')) { localStorage.removeItem('revinsights_campaign_tracker'); campaignTracker = {}; renderTrackerTable(); } });
    loadTracker();
</script>
</body>
